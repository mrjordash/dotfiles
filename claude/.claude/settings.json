{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *--force*)",
      "Bash(git reset *--hard*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.aws/credentials)"
    ],
    "defaultMode": "default"
  },
  "effortLevel": "xhigh",
  "agent": "orchestrator",
  "autoMemoryEnabled": true,
  "theme": "dark"
}
