# Override global ~/.gitignore_global rule that ignores .claude/
!claude/.claude/
!claude/.claude/**

# Zed specific ignores
zed/.config/zed/db/
zed/.config/zed/*.lock
zed/.config/zed/conversations/

# If we create AI slash commands, we might want to include them in the repo
zed/.config/zed/prompts/


# --- Global OS Noise ---
.DS_Store
.Trashes
._*

# --- The "Nuclear" Safety Net (Secrets) ---
# Prevent accidentally committing keys even if you move them here
**/.env
**/.env.*
**/*.pem
**/*.key
**/*.p12
**/*.cer
**/id_rsa
**/id_ed25519
**/gh_token

# --- Shell History & State (Never commit these) ---
# If you accidentally stow a folder with history, this saves you
**/*_history
**/.lesshst
**/fish_history
**/zsh_history
**/bash_history
**/fish_variables

# --- Application Cache/Databases ---
# Just in case you stow a folder that contains binary blobs
**/*.db
**/*.sqlite
**/*.log
**/node_modules/
**/__pycache__/

# --- SSH Specifics ---
# If you stow your .ssh folder, ONLY track the config
ssh/known_hosts
ssh/authorized_keys

# Created by https://www.toptal.com/developers/gitignore/api/macos
# Edit at https://www.toptal.com/developers/gitignore?templates=macos

### macOS ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### macOS Patch ###
# iCloud generated files
*.icloud

# End of https://www.toptal.com/developers/gitignore/api/macos
