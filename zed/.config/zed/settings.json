{
  "theme": "Catppuccin Mocha",
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true
  },
  // FALLBACK FONT (For Icons  )
  "buffer_font_fallbacks": [
    "JetBrainsMono Nerd Font"
  ],
  "terminal": {
    "font_family": "Monaspace Neon",
    "font_features": {
      "calt": true,
      "liga": true,
    },
  },
  "telemetry": {
    "metrics": false,
  },
  "vim_mode": false,
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "available_models": [
        "qwen2.5-coder:14b",
        "qwen2.5-coder:7b",
        "deepseek-r1:14b"
      ]
    }
  },
  "assistant": {
    "version": "2",
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:14b"
    }
  }
}